# ── AI ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Namecheap Private Email ─────────────────────────────────────────────────
# IMAP (incoming mail — used by the poller service)
IMAP_HOST=mail.privateemail.com
IMAP_PORT=993
IMAP_USERNAME=support@yourdomain.com
IMAP_PASSWORD=your_email_password_here
IMAP_POLL_INTERVAL=60

# SMTP (outgoing mail — used by the worker service)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USERNAME=support@yourdomain.com
SMTP_PASSWORD=your_email_password_here
SMTP_FROM_EMAIL=support@yourdomain.com
SMTP_FROM_NAME=Customer Support

# ── Redis (set automatically by docker-compose, override for local dev) ─────
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_NAME=email:inbound
REDIS_CONSUMER_GROUP=complaint-workers
