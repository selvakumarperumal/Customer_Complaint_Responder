# ── AI ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Namecheap Private Email ─────────────────────────────────────────────────
HOST=mail.privateemail.com
PRIVATE_MAIL_EMAIL_ID=support@yourdomain.com
PRIVATE_MAIL_PASSWORD=your_email_password_here

# IMAP (incoming mail — used by both poller and worker services)
IMAP_PORT=993
IMAP_POLL_INTERVAL=60

# SMTP (outgoing mail — used by the worker service)
SMTP_PORT=587
FROM_NAME=Customer Support

# ── Redis (set automatically by docker-compose, override for local dev) ─────
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_NAME=email:inbound
REDIS_CONSUMER_GROUP=complaint-workers
