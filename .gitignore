# ─────────────────────────────────────────────────────────────────────────────
# Terraform
# ─────────────────────────────────────────────────────────────────────────────

# Provider binaries, cached plugins, modules
**/.terraform/
.terraform/

# State files — NEVER commit; they can contain plaintext secrets
*.tfstate
*.tfstate.backup
**/*.tfstate
**/*.tfstate.backup

# Local variable files with secrets
terraform.tfvars
*.auto.tfvars
*.tfvars
**/*.tfvars

# Generated backend configurations
backend.conf
backend.hcl
*.conf
*.hcl
**/*.conf
**/*.hcl

# Local overrides (machine-specific, not for sharing)
override.tf
override.tf.json

# Crash logs generated by Terraform
crash.log
crash.*.log

# Terraform local lock files
*.tfstate.lock.info
**/*.tfstate.lock.info
**/.terraform.lock.hcl

# ─────────────────────────────────────────────────────────────────────────────
# Secrets & credentials
# ─────────────────────────────────────────────────────────────────────────────

# Additional .env patterns
.env.local
.env.*.local
**/*.env
.env

# AWS credential files if accidentally placed in project
.aws/

# Additional sensitive credentials & security files
kubeconfig
*kubeconfig*
*.pem
*.key

# ─────────────────────────────────────────────────────────────────────────────
# IDE / editors
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

