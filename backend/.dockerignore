# Virtual environment — rebuilt inside the image by `uv sync --locked`
.venv/

# Byte-compiled files
__pycache__/
*.py[cod]
*.pyo

# Local secrets — must never enter the image
.env
.env.*
!.env.example

# Editor / OS artefacts
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~

# Test artefacts
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Git
.git/
.gitignore
